                        }
                      }
                    }
                  ]
                }
              },
              {
                "bool": {
                  "filter": [
                    {
                      "term": {
                        "misbehavior": "brakes_on_no_decel"
                      }
                    },
                    {
                      "range": {
                        "accel_g": {
                          "gte": 1.0
