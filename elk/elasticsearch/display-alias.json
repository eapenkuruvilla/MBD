                    {
                      "term": {
                        "misbehavior": "speed_exceeded"
                      }
                    },
                    {
                      "range": {
                        "speed_kmh": {
                          "gte": 200
                        }
                      }
                    }
                  ]
                }
              },
              {
                "bool": {
                  "filter": [
                    {
                      "term": {
                        "misbehavior": "accel_exceeded"
                      }
                    },
                    {
                      "range": {
                        "accel_g": {
                          "gte": 1.5
                        }
                      }
                    }
                  ]
                }
              },
              {
                "bool": {
                  "filter": [
                    {
                      "term": {
                        "misbehavior": "position_jump"
                      }
                    },
                    {
                      "range": {
                        "jump_m": {
                          "gte": 500
                        }
                      }
                    }
                  ]
                }
              },
              {
                "bool": {
                  "filter": [
                    {
                      "term": {
                        "misbehavior": "heading_inconsistency"
