{
  "index_patterns": ["mbd-misbehaviors", "mbd-misbehaviors-*"],
  "priority": 100,
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp":          { "type": "date" },
        "detected_at":         { "type": "date" },
        "record_generated_at": { "type": "keyword" },
        "rsu_id":              { "type": "keyword" },
        "bsm_source":          { "type": "keyword" },
        "vehicle_id":          { "type": "keyword" },
        "msg_cnt":             { "type": "keyword" },
        "location":            { "type": "geo_point" },
        "misbehavior":         { "type": "keyword" },
        "speed_kmh":           { "type": "float" },
        "threshold_kmh":       { "type": "float" },
        "speed_raw":           { "type": "integer" },
        "accel_g":             { "type": "float" },
        "accel_ms2":           { "type": "float" },
        "threshold_g":         { "type": "float" },
        "accel_raw":           { "type": "integer" },
        "jump_m":              { "type": "float" },
        "elapsed_s":           { "type": "float" },
        "implied_speed_kmh":   { "type": "float" },
        "prev_lat":            { "type": "float" },
        "prev_lon":            { "type": "float" }
      }
    }
  }
}
